CHIP Mux8Way16 {
    IN i0[16], i1[16], i2[16], i3[16], i4[16], i5[16], i6[16], i7[16], s0, s1, s2;
    OUT out[16];

    PARTS:
    Mux16(a=i0, b=i1, sel=s0, out=i01);
    Mux16(a=i2, b=i3, sel=s0, out=i23);
    Mux16(a=i4, b=i5, sel=s0, out=i45);
    Mux16(a=i6, b=i7, sel=s0, out=i67);
    Mux16(a=i01, b=i23, sel=s1, out=i0123);
    Mux16(a=i45, b=i67, sel=s1, out=i4567);
    Mux16(a=i0123, b=i4567, sel=s2, out=out);
}